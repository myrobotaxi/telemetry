# Copy this file to .env and fill in real values.
# Never commit .env — it contains secrets.

# ---- Database ----------------------------------------------------------------
# Supabase connection string (production) or local Postgres (development).
# For local dev with docker-compose.yml: use the postgres service below.
DATABASE_URL=postgres://postgres:dev@postgres:5432/myrobotaxi

# ---- Auth --------------------------------------------------------------------
# Random 32+ byte secret used to sign and verify JWT tokens for browser clients.
# IMPORTANT: Generate a unique secret — never use this placeholder value.
# Generate with: openssl rand -hex 32
AUTH_SECRET=CHANGEME-run-openssl-rand-hex-32

# ---- Tesla HTTP Proxy --------------------------------------------------------
# Path to the Tesla app private key used to sign Fleet API commands.
# The proxy is only started when this is set and the file exists.
# For local dev: mount the key file via docker-compose volumes.
TESLA_KEY_FILE=/certs/tesla-private-key.pem

# For Fly.io / containerized deploys: base64-encode secrets as env vars.
# start.sh decodes these to files at startup.
# Generate with: base64 -i private-key.pem | tr -d '\n'
# TESLA_KEY_FILE_B64=
# TLS_CERT_B64=
# TLS_KEY_B64=
# TLS_CA_B64=

# PEM-encoded CA certificate that vehicles use to verify the telemetry server.
# Used when pushing fleet_telemetry_config via the Fleet API.
# Leave empty if the server uses a publicly trusted CA (Let's Encrypt).
# FLEET_TELEMETRY_CA=

# ---- Tesla public key --------------------------------------------------------
# PEM-encoded public key served at .well-known for Tesla app identity verification.
# TESLA_PUBLIC_KEY=

# ---- Logging -----------------------------------------------------------------
# "json" for structured production logs, omit or set to anything else for text.
LOG_FORMAT=json
